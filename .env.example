# Neon PostgreSQL - Pooled connection (for application runtime via Neon adapter)
DATABASE_URL=

# Neon PostgreSQL - Direct connection (for Prisma migrations)
DIRECT_URL=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google AI (Gemini + Embeddings)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_BUCKET_NAME=
# Base64-encoded service account JSON: base64 -w0 key.json
GOOGLE_CLOUD_SA_KEY=
